# Copy to .env (gitignored, auto-loaded on startup) and fill in what you need.
# Secrets never go in config.yaml -- that file is tracked in git.

# Path to the Google Cloud service account JSON. Defaults to
# .credentials/service-account.json if unset.
# GOOGLE_APPLICATION_CREDENTIALS=.credentials/service-account.json

# Override Vertex AI project / location if you don't want to use the values
# read from the service account JSON.
# VERTEX_AI_PROJECT_ID=
# VERTEX_AI_LOCATION=us-central1

# Azure Speech (Audio-to-Audio transcription). Optional -- without these,
# that capability automatically falls back to Gemini ASR.
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=

# Azure OpenAI (text generation: cleanup, content writing, translation,
# question generation). Optional -- without these, those steps
# automatically fall back to Gemini.
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21

# Logging level: DEBUG, INFO, WARNING, ERROR.
# LOG_LEVEL=INFO
